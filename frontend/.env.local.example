# The browser should call local Next API route only.
NEXT_PUBLIC_POLL_INTERVAL_MS=5000

# Optional: override GLB path for the 3D case viewer (defaults to /models/server-case.glb).
# NEXT_PUBLIC_SERVER_CASE_GLB=/models/server-case.glb

# If slide directions look rotated vs your Blender export, try e.g. 90 or -90 (degrees, around world Y).
# NEXT_PUBLIC_CASE_AXIS_YAW_DEGREES=0

# Multiply how far panels travel on full scroll (default 1).
# NEXT_PUBLIC_CASE_EXPLODE_SCALE=1

# Server-side only in Next.js route handler.
# Local dev with backend on this machine: http://localhost:8000
# Docker Compose frontend service: http://backend:8000
# Remote server: https://your-api.example.com
BACKEND_URL=http://localhost:8000
