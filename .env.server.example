# Collector endpoint used by FastAPI inside Docker network
GLANCES_BASE_URL=http://collector:61208
GLANCES_ENDPOINT=/api/3/all

# FastAPI backend behavior
REQUEST_TIMEOUT_SECONDS=3
CACHE_TTL_SECONDS=5

# Set this to your frontend origin(s), comma separated if needed
# Example: https://monitor.yourdomain.com,https://your-project.vercel.app
ALLOWED_ORIGINS=https://monitor.example.com

# Cloudflare Tunnel token from Zero Trust dashboard
CLOUDFLARE_TUNNEL_TOKEN=replace-with-real-token
